# Enable rewrite engine
RewriteEngine On
DirectoryIndex index.html

# Canonicalize legacy /news URLs to /news-radar (avoid duplicate indexing)
# - /news/ -> /news-radar/
# - /news/{category}/ -> /news-radar/
# - /news/{category}/{slug}/ -> /news-radar/{slug}/
RewriteRule ^news/?$ https://%{HTTP_HOST}/news-radar/ [R=301,L]
RewriteRule ^news/[^/]+/?$ https://%{HTTP_HOST}/news-radar/ [R=301,L]
RewriteRule ^news/[^/]+/([^/]+)/?$ https://%{HTTP_HOST}/news-radar/$1/ [R=301,L]


# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
